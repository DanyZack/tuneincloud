---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ArticleBanner from '../components/ArticleBanner.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, subcategory, heroImage } = Astro.props;
---

<html lang="fr">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />
    <main>
      <article>

        <!-- Bannière automatique selon catégorie/subcategory -->
        <ArticleBanner
			title={title}
			category={category ?? 'actualites'}
			subcategory={subcategory}
			pubDate={pubDate}
			heroImage={heroImage}
		/>

        <!-- Contenu de l'article -->
        <div class="prose">
          {updatedDate && (
            <p class="last-updated">
              Mis à jour le {updatedDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
          )}
          <slot />
        </div>

      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
main {
  width: 100%;
  margin: 0;
}

.prose {
  width: 850px;
  max-width: calc(100% - 2rem);
  margin: 3rem auto;
  padding: 0 1rem;
  font-family: 'Raleway', sans-serif;
  font-size: 1rem;
  font-weight: 400;
  line-height: 1.8;
  color: #3d3d5c;
}

.last-updated {
  font-size: 0.78rem;
  color: #b8972a;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  font-style: italic;
}
</style>